# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development   # impostare "production" sul server reale

# ─── Database ─────────────────────────────────────────
DATABASE_URL=postgres://utente:password@host:5432/nomedb

# ─── Autenticazione ───────────────────────────────────
JWT_SECRET=cambia_questo_segreto_con_una_stringa_lunga_e_casuale
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@virtuscaserta.it
ADMIN_PASSWORD=cambia_questa_password

# ─── Email (Gmail) ────────────────────────────────────
EMAIL_USER=tuaemail@gmail.com
EMAIL_PASS=app_password_gmail     # App Password Gmail (non la password normale)
EMAIL_ADMIN=admin@email.com       # Riceve copia degli ordini

# ─── Pagamenti ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
PAYPAL_CLIENT_ID=...

# ─── Instagram ────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=           # Token API Instagram Basic Display
