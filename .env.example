# ─── Server ───────────────────────────────────────────
PORT=3000
NODE_ENV=development   # impostare "production" su Railway (Railway lo imposta automaticamente)

# ─── Database (Supabase) ──────────────────────────────
# Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=

# ─── Supabase Storage (immagini persistenti) ──────────
# Supabase → Project Settings → API
# URL: https://<ref>.supabase.co
# Service Role Key: (non esporre mai — solo lato server)
# Crea un bucket "uploads" in Supabase Storage con visibilità pubblica
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Autenticazione admin ─────────────────────────────
JWT_SECRET=cambia_questo_segreto_con_una_stringa_lunga_e_casuale
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@virtuscaserta.it
ADMIN_PASSWORD=cambia_questa_password

# ─── Email (Gmail) — usata solo per modulo contatti/iscrizioni ──
# Richiede un'App Password Gmail (non la password normale)
# Gmail → Account → Sicurezza → Verifica in 2 passaggi → App password
EMAIL_USER=tuaemail@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_ADMIN=admin@email.com   # riceve copia di ogni nuovo ordine

# ─── Brevo (email transazionali shop/ordini) ──────────
# Brevo → SMTP & API → SMTP → Genera chiave SMTP
BREVO_SMTP_LOGIN=tuaemail@brevo.com
BREVO_SMTP_KEY=xsmtpsib-xxxxxxxxxxxx
BREVO_FROM_EMAIL=noreply@virtuscaserta.it   # mittente verificato in Brevo

# ─── Pagamenti ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
PAYPAL_CLIENT_ID=...

# ─── Instagram ────────────────────────────────────────
# Meta for Developers → Instagram Basic Display → User Token
INSTAGRAM_ACCESS_TOKEN=
